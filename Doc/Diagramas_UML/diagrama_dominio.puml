@startuml
' Diagrama de Dominio - CacaoScan
' Compatible con draw.io
' Basado en los modelos Django reales y migraciones actuales
' Organizado por módulos/aplicaciones

skinparam classAttributeIconSize 0
skinparam linetype ortho

' ============================================
' MÓDULO: DJANGO USER (django.contrib.auth)
' ============================================
package "django.contrib.auth" {
class User {
    + id: Integer
    + username: String
    + email: String
    + password: String
    + first_name: String
    + last_name: String
    + is_staff: Boolean
    + is_active: Boolean
    + is_superuser: Boolean
    + date_joined: DateTime
    + last_login: DateTime
}
}

' ============================================
' MÓDULO: AUTHENTICATION (auth_app)
' ============================================
package "auth_app" {
class EmailVerification {
    + id: Long
    + email: String
    + verification_type: String
    + token: UUID
    + otp_code: String
    + temp_data: JSON
    + created_at: DateTime
    + last_sent: DateTime
    + verified_at: DateTime
    + is_verified: Boolean
}

class UserProfile {
    + id: Long
    + years_experience: Integer
    + farm_size_hectares: Decimal
    + preferred_language: String
    + email_notifications: Boolean
    + created_at: DateTime
    + updated_at: DateTime
}
}

' ============================================
' MÓDULO: PERSONAS (personas)
' ============================================
package "personas" {
class Persona {
    + id: Long
    + numero_documento: String
    + primer_nombre: String
    + segundo_nombre: String
    + primer_apellido: String
    + segundo_apellido: String
    + telefono: String
    + direccion: String
    + fecha_nacimiento: Date
    + fecha_creacion: DateTime
}
}

' ============================================
' MÓDULO: CATÁLOGOS (catalogos)
' ============================================
package "catalogos" {
class Departamento {
    + id: Long
    + codigo: String
    + nombre: String
}

class Municipio {
    + id: Long
    + codigo: String
    + nombre: String
}

class Tema {
    + id: Long
    + codigo: String
    + nombre: String
    + descripcion: String
    + activo: Boolean
}

class Parametro {
    + id: Long
    + codigo: String
    + nombre: String
    + descripcion: String
    + activo: Boolean
    + metadata: JSON
}

class TemaParametro {
    + id: Long
    + tema_id: Long
    + parametro_id: Long
}
}

' ============================================
' MÓDULO: FINCAS (fincas_app)
' ============================================
package "fincas_app" {
class Finca {
    + id: Long
    + created_at: DateTime
    + updated_at: DateTime
    + nombre: String
    + ubicacion: String
    + hectareas: Decimal
    + descripcion: String
    + coordenadas_lat: Decimal
    + coordenadas_lng: Decimal
    + fecha_registro: DateTime
    + activa: Boolean
    + altitud: Integer
    + precipitacion_anual: Decimal
    + temperatura_promedio: Decimal
}

class Lote {
    + id: Long
    + created_at: DateTime
    + updated_at: DateTime
    + identificador: String
    + nombre: String
    + peso_kg: Decimal
    + fecha_recepcion: Date
    + fecha_plantacion: Date
    + fecha_cosecha: Date
    + fecha_procesamiento: Date
    + descripcion: String
    + fecha_registro: DateTime
    + activo: Boolean
    + fecha_creacion: DateTime
    + fecha_actualizacion: DateTime
}
}

' ============================================
' MÓDULO: IMÁGENES (images_app)
' ============================================
package "images_app" {
class CacaoImage {
    + id: Long
    + created_at: DateTime
    + updated_at: DateTime
    + image: String
    + uploaded_at: DateTime
    + processed: Boolean
    + notas: String
    + file_name: String
    + file_size: Integer
    + metadata: JSON
}

class CacaoPrediction {
    + id: Long
    + alto_mm: Decimal
    + ancho_mm: Decimal
    + grosor_mm: Decimal
    + peso_g: Decimal
    + confidence_alto: Decimal
    + confidence_ancho: Decimal
    + confidence_grosor: Decimal
    + confidence_peso: Decimal
    + quality_score: Decimal
    + maturity_percentage: Decimal
    + defects_count: Integer
    + analysis_status: String
    + processing_time: Decimal
    + processing_time_ms: Integer
    + crop_url: String
    + created_at: DateTime
}
}

' ============================================
' MÓDULO: TRAINING (training)
' ============================================
package "training" {
class TrainingJob {
    + id: Long
    + job_id: String
    + job_type: String
    + status: String
    + model_name: String
    + dataset_size: Integer
    + epochs: Integer
    + batch_size: Integer
    + learning_rate: Float
    + config_params: JSON
    + metrics: JSON
    + model_path: String
    + logs: String
    + created_at: DateTime
    + started_at: DateTime
    + completed_at: DateTime
    + error_message: String
    + progress_percentage: Float
}

class ModelMetrics {
    + id: Long
    + model_name: String
    + model_type: String
    + target: String
    + version: String
    + metric_type: String
    + mae: Float
    + mse: Float
    + rmse: Float
    + r2_score: Float
    + mape: Float
    + additional_metrics: JSON
    + dataset_size: Integer
    + train_size: Integer
    + validation_size: Integer
    + test_size: Integer
    + epochs: Integer
    + batch_size: Integer
    + learning_rate: Float
    + model_params: JSON
    + training_time_seconds: Integer
    + inference_time_ms: Float
    + stability_score: Float
    + knowledge_retention: Float
    + notes: String
    + is_best_model: Boolean
    + is_production_model: Boolean
    + created_at: DateTime
    + updated_at: DateTime
}
}

' ============================================
' MÓDULO: NOTIFICACIONES (notifications)
' ============================================
package "notifications" {
class Notification {
    + id: Long
    + titulo: String
    + mensaje: String
    + leida: Boolean
    + fecha_creacion: DateTime
    + fecha_lectura: DateTime
    + datos_extra: JSON
    + created_at: DateTime
    + updated_at: DateTime
}
}

' ============================================
' MÓDULO: AUDITORÍA (audit)
' ============================================
package "audit" {
class ActivityLog {
    + id: Long
    + action: String
    + content_type_id: Integer
    + object_id: Integer
    + resource_type: String
    + resource_id: Integer
    + details: JSON
    + ip_address: String
    + user_agent: String
    + timestamp: DateTime
}

class LoginHistory {
    + id: Long
    + ip_address: String
    + user_agent: String
    + login_time: DateTime
    + logout_time: DateTime
    + session_duration: Duration
    + login_successful: Boolean
    + failure_reason: String
}
}

' ============================================
' MÓDULO: REPORTES (reports)
' ============================================
package "reports" {
class ReporteGenerado {
    + id: Long
    + titulo: String
    + descripcion: String
    + archivo: String
    + nombre_archivo: String
    + ruta_archivo: String
    + tamano_archivo: Integer
    + parametros: JSON
    + filtros_aplicados: JSON
    + fecha_solicitud: DateTime
    + fecha_generacion: DateTime
    + fecha_expiracion: DateTime
    + tiempo_generacion: Duration
    + mensaje_error: String
    + created_at: DateTime
    + updated_at: DateTime
}
}

' ============================================
' MÓDULO: CORE (core)
' ============================================
package "core" {
abstract class TimeStampedModel {
    + created_at: DateTime
    + updated_at: DateTime
}

class SystemSettings {
    + id: Long
    + nombre_sistema: String
    + email_contacto: String
    + lema: String
    + logo: String
    + recaptcha_enabled: Boolean
    + session_timeout: Integer
    + login_attempts: Integer
    + two_factor_auth: Boolean
    + active_model: String
    + last_training: DateTime
    + created_at: DateTime
    + updated_at: DateTime
}
}

' ============================================
' RELACIONES ENTRE ENTIDADES
' ============================================

' Relaciones de Usuario (django.contrib.auth.User)
User "1" ||--|| Persona : "tiene"
User "1" ||--o| UserProfile : "tiene"
User "1" ||--o{ EmailVerification : "tiene (user)"
User "1" ||--o{ Finca : "es propietario (agricultor)"
User "1" ||--o{ CacaoImage : "sube"
User "1" ||--o{ CacaoPrediction : "genera (opcional)"
User "1" ||--o{ TrainingJob : "crea (created_by)"
User "1" ||--o{ ModelMetrics : "crea (created_by)"
User "1" ||--o{ Notification : "recibe"
User "1" ||--o{ ActivityLog : "realiza"
User "1" ||--o{ LoginHistory : "tiene"
User "1" ||--o{ ReporteGenerado : "solicita (usuario)"

' Relaciones de Persona
Persona "N" }o--|| Parametro : "tipo_documento (TIPO_DOC)"
Persona "N" }o--|| Parametro : "genero (SEXO)"
Persona "N" }o--o| Municipio : "reside_en"

' Relaciones de UserProfile
UserProfile "N" }o--o| Municipio : "ubicado_en"

' Relaciones de EmailVerification
EmailVerification "N" }o--o| User : "verifica (opcional)"

' Relaciones de Finca
Finca "N" }o--|| Municipio : "ubicada_en"
Finca "N" }o--o| Parametro : "tipo_suelo (TEMA_TIPO_SUELO)"
Finca "N" }o--o| Parametro : "clima (TEMA_CLIMA)"
Finca "N" }o--o| Parametro : "estado (TEMA_ESTADO_FINCA)"
Finca "1" ||--o{ Lote : "contiene"

' Relaciones de Lote
Lote "N" }o--|| Parametro : "variedad (TEMA_VARIEDAD_CACAO)"
Lote "N" }o--o| Parametro : "estado (TEMA_ESTADO_LOTE)"
Lote "1" ||--o{ CacaoImage : "contiene"

' Relaciones de CacaoImage
CacaoImage "N" }o--o| Parametro : "file_type (TEMA_TIPO_ARCHIVO)"

' Relaciones de CacaoPrediction
CacaoPrediction "1" ||--|| CacaoImage : "analiza"
CacaoPrediction "N" }o--|| Parametro : "model_version (TEMA_VERSION_MODELO)"
CacaoPrediction "N" }o--|| Parametro : "device_used (TEMA_TIPO_DISPOSITIVO)"

' Relaciones de Notification
Notification "N" }o--|| Parametro : "tipo (TEMA_TIPO_NOTIFICACION)"

' Relaciones de ReporteGenerado
ReporteGenerado "N" }o--|| Parametro : "tipo_reporte (TEMA_TIPO_REPORTE)"
ReporteGenerado "N" }o--|| Parametro : "formato (TEMA_FORMATO_REPORTE)"
ReporteGenerado "N" }o--|| Parametro : "estado (TEMA_ESTADO_REPORTE)"

' Relaciones de ModelMetrics
ModelMetrics "N" }o--o| TrainingJob : "relacionado_con"

' Relaciones de Catálogos
Departamento "1" ||--o{ Municipio : "contiene"
Tema "1" ||--o{ Parametro : "tiene"
TemaParametro }o--|| Tema : "tema"
TemaParametro }o--|| Parametro : "parametro"

@enduml
