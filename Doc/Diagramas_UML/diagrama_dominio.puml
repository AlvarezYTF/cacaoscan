@startuml
' Diagrama de Dominio - CacaoScan
' Compatible con draw.io
' Basado en el esquema SQL real de la base de datos

skinparam classAttributeIconSize 0
skinparam linetype ortho

' ============================================
' ENTIDADES PRINCIPALES DEL DOMINIO
' ============================================

class User {
    + id: Integer
    + password: String
    + last_login: DateTime
    + is_superuser: Boolean
    + username: String
    + first_name: String
    + last_name: String
    + email: String
    + is_staff: Boolean
    + is_active: Boolean
    + date_joined: DateTime
}

class Persona {
    + id: Long
    + numero_documento: String
    + primer_nombre: String
    + segundo_nombre: String
    + primer_apellido: String
    + segundo_apellido: String
    + telefono: String
    + direccion: String
    + fecha_nacimiento: Date
    + fecha_creacion: DateTime
}

class UserProfile {
    + id: Long
    + years_experience: Integer
    + farm_size_hectares: Decimal
    + preferred_language: String
    + email_notifications: Boolean
    + created_at: DateTime
    + updated_at: DateTime
}

class EmailVerification {
    + id: Long
    + email: String
    + verification_type: String
    + token: UUID
    + otp_code: String
    + temp_data: JSON
    + created_at: DateTime
    + last_sent: DateTime
    + verified_at: DateTime
    + is_verified: Boolean
}

class Finca {
    + id: Long
    + created_at: DateTime
    + updated_at: DateTime
    + nombre: String
    + ubicacion: String
    + hectareas: Decimal
    + descripcion: String
    + coordenadas_lat: Decimal
    + coordenadas_lng: Decimal
    + fecha_registro: DateTime
    + activa: Boolean
    + altitud: Integer
    + precipitacion_anual: Decimal
    + temperatura_promedio: Decimal
}

class Lote {
    + id: Long
    + created_at: DateTime
    + updated_at: DateTime
    + identificador: String
    + nombre: String
    + fecha_plantacion: Date
    + fecha_cosecha: Date
    + area_hectareas: Decimal
    + descripcion: String
    + coordenadas_lat: Decimal
    + coordenadas_lng: Decimal
    + fecha_registro: DateTime
    + activo: Boolean
    + edad_plantas: Integer
    + fecha_creacion: DateTime
    + fecha_actualizacion: DateTime
}

class CacaoImage {
    + id: Long
    + created_at: DateTime
    + updated_at: DateTime
    + image: String
    + uploaded_at: DateTime
    + processed: Boolean
    + notas: String
    + file_name: String
    + file_size: Integer
    + metadata: JSON
}

class CacaoPrediction {
    + id: Long
    + alto_mm: Decimal
    + ancho_mm: Decimal
    + grosor_mm: Decimal
    + peso_g: Decimal
    + confidence_alto: Decimal
    + confidence_ancho: Decimal
    + confidence_grosor: Decimal
    + confidence_peso: Decimal
    + quality_score: Decimal
    + maturity_percentage: Decimal
    + defects_count: Integer
    + analysis_status: String
    + processing_time: Decimal
    + processing_time_ms: Integer
    + crop_url: String
    + created_at: DateTime
}

class TrainingJob {
    + id: Long
    + job_id: String
    + job_type: String
    + status: String
    + model_name: String
    + dataset_size: Integer
    + epochs: Integer
    + batch_size: Integer
    + learning_rate: Float
    + config_params: JSON
    + metrics: JSON
    + model_path: String
    + logs: String
    + created_at: DateTime
    + started_at: DateTime
    + completed_at: DateTime
    + error_message: String
    + progress_percentage: Float
}

class ModelMetrics {
    + id: Long
    + model_name: String
    + model_type: String
    + target: String
    + version: String
    + metric_type: String
    + mae: Float
    + mse: Float
    + rmse: Float
    + r2_score: Float
    + mape: Float
    + additional_metrics: JSON
    + dataset_size: Integer
    + train_size: Integer
    + validation_size: Integer
    + test_size: Integer
    + epochs: Integer
    + batch_size: Integer
    + learning_rate: Float
    + model_params: JSON
    + training_time_seconds: Integer
    + inference_time_ms: Float
    + stability_score: Float
    + knowledge_retention: Float
    + notes: String
    + is_best_model: Boolean
    + is_production_model: Boolean
    + created_at: DateTime
    + updated_at: DateTime
}

class Notification {
    + id: Long
    + titulo: String
    + mensaje: String
    + leida: Boolean
    + fecha_creacion: DateTime
    + fecha_lectura: DateTime
    + datos_extra: JSON
    + created_at: DateTime
    + updated_at: DateTime
}

class ActivityLog {
    + id: Long
    + action: String
    + modelo: String
    + objeto_id: String
    + descripcion: String
    + ip_address: String
    + user_agent: String
    + datos_antes: JSON
    + datos_despues: JSON
    + timestamp: DateTime
    + resource_type: String
    + resource_id: Integer
    + details: JSON
    + content_type_id: Integer
    + object_id: Integer
}

class LoginHistory {
    + id: Long
    + ip_address: String
    + user_agent: String
    + login_time: DateTime
    + logout_time: DateTime
    + session_duration: Duration
    + login_successful: Boolean
    + failure_reason: String
}

class ReporteGenerado {
    + id: Long
    + titulo: String
    + descripcion: String
    + archivo: String
    + nombre_archivo: String
    + ruta_archivo: String
    + tamano_archivo: Integer
    + parametros: JSON
    + filtros_aplicados: JSON
    + fecha_solicitud: DateTime
    + fecha_generacion: DateTime
    + fecha_expiracion: DateTime
    + tiempo_generacion: Duration
    + mensaje_error: String
    + created_at: DateTime
    + updated_at: DateTime
}

class SystemSettings {
    + id: Long
    + nombre_sistema: String
    + email_contacto: String
    + lema: String
    + logo: String
    + recaptcha_enabled: Boolean
    + session_timeout: Integer
    + login_attempts: Integer
    + two_factor_auth: Boolean
    + active_model: String
    + last_training: DateTime
    + created_at: DateTime
    + updated_at: DateTime
}

' ============================================
' CATÁLOGOS - ENTIDADES DE REFERENCIA
' ============================================

class Departamento {
    + id: Long
    + codigo: String
    + nombre: String
}

class Municipio {
    + id: Long
    + codigo: String
    + nombre: String
}

class Tema {
    + id: Long
    + codigo: String
    + nombre: String
    + descripcion: String
    + activo: Boolean
}

class Parametro {
    + id: Long
    + codigo: String
    + nombre: String
    + descripcion: String
    + activo: Boolean
}

class TemaParametro {
    + id: Long
    + tema_id: Long
    + parametro_id: Long
}

class VariedadCacao {
    + id: Long
    + codigo: String
    + nombre: String
    + descripcion: String
    + activo: Boolean
}

class TipoSuelo {
    + id: Long
    + codigo: String
    + nombre: String
    + descripcion: String
    + activo: Boolean
}

class Clima {
    + id: Long
    + codigo: String
    + nombre: String
    + descripcion: String
    + activo: Boolean
}

class EstadoFinca {
    + id: Long
    + codigo: String
    + nombre: String
    + descripcion: String
    + activo: Boolean
}

class EstadoLote {
    + id: Long
    + codigo: String
    + nombre: String
    + descripcion: String
    + activo: Boolean
}

class TipoReporte {
    + id: Long
    + codigo: String
    + nombre: String
    + descripcion: String
    + activo: Boolean
}

class FormatoReporte {
    + id: Long
    + codigo: String
    + nombre: String
    + descripcion: String
    + activo: Boolean
}

class EstadoReporte {
    + id: Long
    + codigo: String
    + nombre: String
    + descripcion: String
    + activo: Boolean
}

class TipoNotificacion {
    + id: Long
    + codigo: String
    + nombre: String
    + descripcion: String
    + activo: Boolean
}

class TipoArchivo {
    + id: Long
    + codigo: String
    + nombre: String
    + mime_type: String
    + descripcion: String
    + activo: Boolean
}

class TipoDispositivo {
    + id: Long
    + codigo: String
    + nombre: String
    + descripcion: String
    + activo: Boolean
}

class VersionModelo {
    + id: Long
    + codigo: String
    + nombre: String
    + descripcion: String
    + fecha_lanzamiento: Date
    + activo: Boolean
}

' ============================================
' RELACIONES ENTRE ENTIDADES
' ============================================

' Relaciones de Usuario
User "1" ||--|| Persona : "tiene"
User "1" ||--|| UserProfile : "tiene"
User "1" ||--o{ EmailVerification : "tiene"
User "1" ||--o{ Finca : "es propietario (agricultor)"
User "1" ||--o{ CacaoImage : "sube"
User "1" ||--o{ CacaoPrediction : "genera"
User "1" ||--o{ TrainingJob : "crea (created_by)"
User "1" ||--o{ ModelMetrics : "crea (created_by)"
User "1" ||--o{ Notification : "recibe"
User "1" ||--o{ ActivityLog : "realiza"
User "1" ||--o{ LoginHistory : "tiene"
User "1" ||--o{ ReporteGenerado : "solicita (usuario)"

' Relaciones de Persona
Persona "N" }o--|| Parametro : "tipo_documento"
Persona "N" }o--|| Parametro : "genero"
Persona "N" }o--o| Municipio : "reside_en"

' Relaciones de UserProfile
UserProfile "N" }o--o| Municipio : "ubicado_en"

' Relaciones de Finca
Finca "N" }o--|| Municipio : "ubicada_en"
Finca "N" }o--o| TipoSuelo : "tiene"
Finca "N" }o--o| Clima : "tiene"
Finca "N" }o--o| EstadoFinca : "tiene"
Finca "1" ||--o{ Lote : "contiene"

' Relaciones de Lote
Lote "N" }o--|| VariedadCacao : "tiene"
Lote "N" }o--o| EstadoLote : "tiene"
Lote "1" ||--o{ CacaoImage : "contiene"

' Relaciones de CacaoImage
CacaoImage "N" }o--o| TipoArchivo : "tiene"

' Relaciones de CacaoPrediction
CacaoPrediction "1" ||--|| CacaoImage : "analiza"
CacaoPrediction "N" }o--|| VersionModelo : "usa (model_version)"
CacaoPrediction "N" }o--|| TipoDispositivo : "usa (device_used)"

' Relaciones de Notification
Notification "N" }o--|| TipoNotificacion : "tiene (tipo)"

' Relaciones de ReporteGenerado
ReporteGenerado "N" }o--|| TipoReporte : "tiene (tipo_reporte)"
ReporteGenerado "N" }o--|| FormatoReporte : "tiene (formato)"
ReporteGenerado "N" }o--|| EstadoReporte : "tiene (estado)"

' Relaciones de ModelMetrics
ModelMetrics "N" }o--o| TrainingJob : "relacionado_con"

' Relaciones de Catálogos
Departamento "1" ||--o{ Municipio : "contiene"
Tema "N" }o--o{ Parametro : "relacionado_con"
TemaParametro }o--|| Tema : "tema"
TemaParametro }o--|| Parametro : "parametro"

@enduml
